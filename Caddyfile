{
    admin off
    log {
        level INFO
    }
}

(dns_bunny) {
    tls {
        dns bunny {env.BUNNY_API_KEY}
    }
}

(security_headers) {
    header {
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
        X-XSS-Protection "1; mode=block"
        X-DNS-Prefetch-Control "off"
        -Server
    }
}

(tls_settings) {
    tls {
        protocols tls1.2 tls1.3
        ciphers TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384 TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384
    }
}

(standard_config) {
    import tls_settings
    import security_headers
    import dns_bunny
}

# Фронтенд — сайт + TMA на разных доменах, один контейнер frontend:3000
{$FRONTEND_DOMAINS} {
    import standard_config

    handle_errors {
        @error500 {
            expression {http.error.status_code} == 500
        }
        respond @error500 "{ \"error\": \"Internal Server Error\" }" 500
        header @error500 Content-Type application/json
    }

    reverse_proxy frontend:3000 {
        transport http {
            read_buffer 4096
            read_timeout 10s
            write_timeout 10s
            keepalive 60s
        }
    }

    header Content-Security-Policy "default-src 'self'; base-uri 'none'; object-src 'none'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: https:; script-src-elem 'self' 'unsafe-inline' blob: https:; script-src-attr 'unsafe-inline'; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: blob: https:; font-src 'self' data: https:; connect-src 'self' https: wss:; frame-src 'self' https: blob: data:; child-src 'self' https: blob: data:; media-src 'self' data: blob: https:; worker-src 'self' blob:; manifest-src 'self'; form-action 'self' https:; frame-ancestors https://web.telegram.org https://*.telegram.org;"

    log {
        output file /var/log/caddy/frontend.access.log {
            roll_size 100MB
            roll_keep 5
        }
        format json
    }
}

api.{$MAIN_DOMAIN} {
    import standard_config

    handle_errors {
        @error500 {
            expression {http.error.status_code} == 500
        }
        respond @error500 "{ \"error\": \"Internal Server Error\" }" 500
        header @error500 Content-Type application/json
    }

    reverse_proxy api:4000 {
        transport http {
            read_buffer 4096
            read_timeout 10s
            write_timeout 10s
            keepalive 60s
        }
    }

    header Content-Security-Policy "default-src 'none'; connect-src 'self'; frame-ancestors https://web.telegram.org https://*.telegram.org;"

    log {
        output file /var/log/caddy/api.access.log {
            roll_size 100MB
            roll_keep 5
        }
        format json
    }
}

*.frps.{$MAIN_DOMAIN} {
    import standard_config

    reverse_proxy frps:8090 {
        transport http {
            read_timeout 300s
            write_timeout 300s
            keepalive 120s
        }
    }

    log {
        output file /var/log/caddy/frps-wildcard.access.log {
            roll_size 100MB
            roll_keep 5
        }
        format json
    }
}

rem.{$MAIN_DOMAIN} {
    import standard_config

    reverse_proxy remnawave:3020 {
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-For {remote_host}
        header_up X-Real-IP {remote_host}
        header_up Host {host}

        transport http {
            read_timeout 300s
            write_timeout 300s
            keepalive 120s
        }
    }
}

grafana.{$MAIN_DOMAIN} {
    import standard_config

    reverse_proxy grafana:3000 {
    }

    header Content-Security-Policy "
        default-src 'self';
        script-src 'self' 'unsafe-inline' 'unsafe-eval';
        style-src 'self' 'unsafe-inline';
        img-src 'self' data:;
        frame-ancestors https://web.telegram.org https://*.telegram.org;
    "
}

# Домен-маска для подписок — прячет rem.MAIN_DOMAIN/api/sub/* за коротким адресом
{$SUB_DOMAIN} {
    import standard_config

    rewrite * /api/sub{uri}

    reverse_proxy remnawave:3020 {
        # header_up Host rem.{$MAIN_DOMAIN}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-For {remote_host}
        header_up X-Real-IP {remote_host}

        transport http {
            read_timeout 300s
            write_timeout 300s
            keepalive 120s
        }
    }

    log {
        output file /var/log/caddy/sub.access.log {
            roll_size 100MB
            roll_keep 5
        }
        format json
    }
}

# FRP Control (WebSocket)
frp.{$MAIN_DOMAIN} {
    import standard_config

    reverse_proxy frps:7000 {
        header_up Host {upstream_hostport}
        header_up X-Real-IP {remote_host}
    }

    log {
        output file /var/log/caddy/frp.access.log {
            roll_size 100MB
            roll_keep 5
        }
        format json
    }
}
